      "Bash(mvnw *)",
      "Bash(gradle *)",
      "Bash(./gradlew *)",
      "Bash(java *)",
      "Bash(javac *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(pnpm *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(jq *)",
      "Bash(unzip *)",
      "Bash(tar *)",
      "Bash(python *)",
